{
  "jobs": [
    {
      "id": "metals-monitor",
      "type": "markets",
      "description": "Gold/silver + optional BTC/ETH via Gold API",
      "enabled": true,
      "assets": [
        {
          "symbol": "XAU", "label": "Gold", "keyLevels": [2000, 2500, 3000],
          "delivery": {
            "slack": ["#markets"],
            "ntfy": true,
            "ntfyPriority": "high",
            "template": "marketAlert"
          }
        },
        {
          "symbol": "XAG", "label": "Silver", "keyLevels": [25, 30, 35],
          "delivery": {
            "slack": ["#markets"],
            "ntfy": true,
            "ntfyPriority": "high",
            "template": "marketAlert"
          }
        },
        {
          "symbol": "BTC", "label": "Bitcoin", "keyLevels": [50000, 75000, 100000],
          "delivery": {
            "slack": ["#markets"],
            "ntfy": false,
            "template": "marketAlert"
          }
        },
        {
          "symbol": "ETH", "label": "Ethereum", "keyLevels": [2500, 3500, 5000],
          "delivery": {
            "slack": ["#markets"],
            "ntfy": false,
            "template": "marketAlert"
          }
        }
      ],
      "alertRules": {
        "percentMoveThreshold": 2.0,
        "velocityWindowMinutes": 60,
        "suppressDuplicateDeltaPct": 0.5
      },
      "apiBaseUrl": "https://gold-api.com",
      "scoringProfile": "metals",
      "osintProfile": "shortContext",
      "routingProfile": "markets",
      "overrideQuietWindow": false,
      "scheduleHint": "*/10 6-23 * * 1-5",
      "deliveryPolicy": {
        "mode": "autoPost",
        "maxItemsPerRun": 5
      }
    }
  ]
}
