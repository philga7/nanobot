# Optional: copy to .env.qdrant (gitignored) for Qdrant runtime secrets.
# Loaded only by the qdrant service (see docker-compose.yml env_file).
#
# API key (enforces api-key header on REST/gRPC). See:
# https://qdrant.tech/documentation/guides/security/
#
# QDRANT__SERVICE__API_KEY=your-long-random-secret
