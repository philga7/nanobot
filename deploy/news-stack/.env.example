# Copy to `.env` in this directory for docker compose variable substitution.
# Do not commit real secrets; this file is the template only.

# --- Host port mapping (published as 127.0.0.1:<port> in compose) ---

# Crucix (profile: full) — host port mapped to container 3117
CRUCIX_PORT=3117

# 7/24 Office (profile: full) — host port mapped to container 8080 (default 8082 avoids host 8080 clashes)
OFFICE_PORT=8082

# Qdrant REST API (host ports when running compose from this directory)
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Optional: pass through into containers (only if you add matching `environment:` in compose) ---
# Prefer service-specific files instead:
#   - Qdrant: `.env.qdrant` (see `.env.qdrant.example`)
#   - Crucix: `vendor/crucix/.env` (from upstream `.env.example`)
#   - Office: `vendor/724-office/.env` if upstream supports it, else `config.json` + bind mount (see README)
