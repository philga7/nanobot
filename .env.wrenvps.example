##### Instance identity / workspace #####
NANOBOT_AGENTS__DEFAULTS__INSTANCE_NAME=WrenVPS
NANOBOT_AGENTS__DEFAULTS__WORKSPACE=/root/.wrenvps/workspace

##### Web search / SearXNG (single source of truth) #####
# Adjust SEARXNG_BASE_URL if your search backend runs elsewhere
SEARXNG_BASE_URL=http://searxng:8080
NANOBOT_TOOLS__WEB__SEARCH__BACKEND=searxng
NANOBOT_TOOLS__WEB__SEARCH__SEARXNG_URL=${SEARXNG_BASE_URL}

##### Provider (custom / Ollama or other) #####
# Set these to your actual provider credentials on the VPS
NANOBOT_PROVIDERS__CUSTOM__API_KEY=YOUR_CUSTOM_API_KEY
NANOBOT_PROVIDERS__CUSTOM__API_BASE=https://ollama.com/api

##### Telegram channel #####
NANOBOT_CHANNELS__TELEGRAM__TOKEN=YOUR_TELEGRAM_BOT_TOKEN
NANOBOT_CHANNELS__TELEGRAM__ALLOW_FROM=YOUR_TELEGRAM_USER_ID

##### Slack channel #####
NANOBOT_CHANNELS__SLACK__BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
NANOBOT_CHANNELS__SLACK__APP_TOKEN=YOUR_SLACK_APP_TOKEN

##### Todo MCP (Xczer/todo-mcp-server) #####
# Path inside container where todo DB should live
TODO_DB_PATH=/root/.wrenvps/todos.db
NANOBOT_TOOLS__MCP_SERVERS__TODO__ENV__TODO_DB_PATH=${TODO_DB_PATH}

##### Memento MCP (iAchilles/memento) #####
MEMENTO_DB_PATH=/root/.wrenvps/memento.db
NANOBOT_TOOLS__MCP_SERVERS__MEMENTO__ENV__MEMENTO_DB_PATH=${MEMENTO_DB_PATH}

##### ntfy MCP #####
NTFY_TOPIC=wrenvps-notifications
NTFY_URL=https://ntfy.example.com
NTFY_TOKEN=YOUR_NTFY_TOKEN

NANOBOT_TOOLS__MCP_SERVERS__NTFY__ENV__NTFY_TOPIC=${NTFY_TOPIC}
NANOBOT_TOOLS__MCP_SERVERS__NTFY__ENV__NTFY_URL=${NTFY_URL}
NANOBOT_TOOLS__MCP_SERVERS__NTFY__ENV__NTFY_TOKEN=${NTFY_TOKEN}

##### library-mcp (Library) #####
NANOBOT_TOOLS__MCP_SERVERS__LIBRARY__COMMAND=python
NANOBOT_TOOLS__MCP_SERVERS__LIBRARY__ARGS__0=sqlite-paper-fastmcp-server.py
NANOBOT_TOOLS__MCP_SERVERS__LIBRARY__CWD=/app/services/library-mcp
NANOBOT_TOOLS__MCP_SERVERS__LIBRARY__ENV__SQLITE_DB_PATH=/root/.wrenvps/library/sources.db

##### bird-api (X / Twitter via bird CLI) #####
AUTH_TOKEN=YOUR_BIRD_AUTH_TOKEN
CT0=YOUR_BIRD_CT0_COOKIE

##### news-pipeline-mcp / history base #####
NANOBOT_BASE_DIR=/root/.wrenvps
NANOBOT_TOOLS__MCP_SERVERS__NEWSPIPELINE__ENV__OPENCLAW_BASE_DIR=${NANOBOT_BASE_DIR}
NANOBOT_TOOLS__MCP_SERVERS__NEWSPIPELINE__ENV__SEARXNG_BASE_URL=${SEARXNG_BASE_URL}
